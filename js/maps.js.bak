// Add a marker to the map
export function addMarker(position, options = {}) {
  if (!map) {
    console.error("Map not initialized. Call initMap first.")
    return null
  }
  
  if (!window.google || !window.google.maps) {
    console.error("Google Maps API not loaded")
    return null
  }

  // Remove existing marker if requested
  if (marker && options.replaceExisting !== false) {
    marker.setMap(null)
  }

  const defaultOptions = {
    position: position,
    map: map,
    draggable: true,
    animation: google.maps.Animation.DROP,
  }

  const markerOptions = { ...defaultOptions, ...options }

  try {
    // Create the marker
    const newMarker = new google.maps.Marker(markerOptions)
    
    // Make this the current marker if replacing
    if (options.replaceExisting !== false) {
      marker = newMarker
    }

    // Add drag event listener if marker is draggable
    if (markerOptions.draggable) {
      google.maps.event.addListener(newMarker, "dragend", () => {
        const position = newMarker.getPosition()
        if (options.onDragEnd && typeof options.onDragEnd === 'function') {
          options.onDragEnd(position)
        }
      })
    }

    // Add click listener if provided
    if (options.onClick && typeof options.onClick === 'function') {
      google.maps.event.addListener(newMarker, "click", () => {
        options.onClick(newMarker)
      })
    }

    return newMarker
  } catch (error) {
    console.error("Error adding marker:", error)
    return null
  }
}

// Center the map on a specific position
export function centerMap(position, zoom) {
  if (!map) {
    console.error("Map not initialized. Call initMap first.")
    return
  }

  try {
    map.setCenter(position)
    if (zoom !== undefined) {
      map.setZoom(zoom)
    }
  } catch (error) {
    console.error("Error centering map:", error)
  }
}

// Get the current position of the marker
export function getMarkerPosition() {
  if (!marker) {
    console.error("Marker not initialized. Call addMarker first.")
    return null
  }

  try {
    return marker.getPosition().toJSON()
  } catch (error) {
    console.error("Error getting marker position:", error)
    return null
  }
}

// Update the position of an existing marker
export function updateMarkerPosition(position) {
  if (!marker) {
    console.error("Marker not initialized. Call addMarker first.")
    return
  }

  try {
    marker.setPosition(position)
  } catch (error) {
    console.error("Error updating marker position:", error)
  }
}

// Geocode an address to get its coordinates
export async function geocodeAddress(address) {
  if (!window.google || !window.google.maps || !window.google.maps.Geocoder) {
    console.error("Google Maps Geocoder not available")
    return null
  }

  if (!geocoder) {
    geocoder = new google.maps.Geocoder()
  }

  try {
    const { results, status } = await new Promise((resolve, reject) => {
      geocoder.geocode({ address: address }, (results, status) => {
        resolve({ results, status })
      })
    })

    if (status === "OK" && results && results.length > 0) {
      const location = results[0].geometry.location
      return {
        lat: location.lat(),
        lng: location.lng(),
        formattedAddress: results[0].formatted_address
      }
    } else {
      console.error("Geocode failed:", status)
      return null
    }
  } catch (error) {
    console.error("Error in geocodeAddress:", error)
    return null
  }
}

// Reverse geocode coordinates to get an address
export async function reverseGeocode(position) {
  if (!window.google || !window.google.maps || !window.google.maps.Geocoder) {
    console.error("Google Maps Geocoder not available")
    return null
  }

  if (!geocoder) {
    geocoder = new google.maps.Geocoder()
  }

  try {
    // Ensure position is in the correct format
    const latLng = position instanceof google.maps.LatLng
      ? position
      : new google.maps.LatLng(position.lat, position.lng)

    const { results, status } = await new Promise((resolve, reject) => {
      geocoder.geocode({ location: latLng }, (results, status) => {
        resolve({ results, status })
      })
    })

    if (status === "OK" && results && results.length > 0) {
      return results[0].formatted_address
    } else {
      console.error("Reverse geocode failed:", status)
      return null
    }
  } catch (error) {
    console.error("Error in reverseGeocode:", error)
    return null
  }
}

// Get the current user's location
export async function getCurrentLocation() {
  if (!navigator.geolocation) {
    throw new Error("Geolocation is not supported by this browser")
  }

  try {
    const position = await new Promise((resolve, reject) => {
      navigator.geolocation.getCurrentPosition(resolve, reject, {
        enableHighAccuracy: true,
        timeout: 10000,
        maximumAge: 0
      })
    })

    return {
      lat: position.coords.latitude,
      lng: position.coords.longitude
    }
  } catch (error) {
    console.error("Error getting current location:", error)
    throw error
  }
}

// Initialize Google Places Autocomplete on an input field
export function initAutocomplete(inputId, options = {}) {
  if (!window.google || !window.google.maps || !window.google.maps.places || !window.google.maps.places.Autocomplete) {
    console.error("Google Maps Places API not available")
    return null
  }

  const input = document.getElementById(inputId)
  if (!input) {
    console.error(`Input element with id '${inputId}' not found`)
    return null
  }

  const defaultOptions = {
    types: ["geocode"],
    componentRestrictions: {}, // No country restriction by default
    fields: ["address_components", "geometry", "formatted_address"]
  }

  const autocompleteOptions = { ...defaultOptions, ...options }

  try {
    // Create autocomplete instance
    const autocomplete = new google.maps.places.Autocomplete(input, autocompleteOptions)

    // Add place changed listener if callback provided
    if (options.onPlaceChanged && typeof options.onPlaceChanged === "function") {
      autocomplete.addListener("place_changed", () => {
        const place = autocomplete.getPlace()
        options.onPlaceChanged(place)
      })
    }

    return autocomplete
  } catch (error) {
    console.error("Error initializing autocomplete:", error)
    return null
  }
}

// Initialize a complete map picker with input and coordinates
export function initMapPicker(mapContainerId, addressInputId, latInputId, lngInputId, options = {}) {
  // Store references to DOM elements
  const mapContainer = document.getElementById(mapContainerId)
  const addressInput = document.getElementById(addressInputId)
  const latInput = document.getElementById(latInputId)
  const lngInput = document.getElementById(lngInputId)

  // Validate required elements
  if (!mapContainer || !addressInput || !latInput || !lngInput) {
    console.error("Required DOM elements not found for map picker")
    return null
  }

  // Default options
  const defaultOptions = {
    center: { lat: 37.7749, lng: -122.4194 }, // Default to San Francisco
    zoom: 12,
    useCurrentLocation: false
  }

  const pickerOptions = { ...defaultOptions, ...options }

  // Initialize map
  const mapInstance = initMap(mapContainerId, pickerOptions)
  if (!mapInstance) {
    // If map fails to initialize, wait for Google Maps to load then try again
    document.addEventListener("googleMapsLoaded", () => {
      initMapPicker(mapContainerId, addressInputId, latInputId, lngInputId, options)
    }, { once: true })
    return null
  }

  // Add marker
  let pickerMarker = addMarker(pickerOptions.center, {
    draggable: true,
    onDragEnd: (position) => {
      updateFormWithPosition(position, addressInput, latInput, lngInput)
    }
  })

  // Set initial values in form
  updateFormWithPosition(pickerOptions.center, addressInput, latInput, lngInput)

  // Initialize autocomplete on address input
  const autocompleteInstance = initAutocomplete(addressInputId, {
    onPlaceChanged: (place) => {
      if (!place.geometry) {
        console.error("Place selected has no geometry")
        return
      }

      // Update map and marker
      map.setCenter(place.geometry.location)
      updateMarkerPosition(place.geometry.location)

      // Update form
      updateFormWithPosition(place.geometry.location, addressInput, latInput, lngInput)
    }
  })

  // Add click listener to map
  mapInstance.addListener("click", (event) => {
    updateMarkerPosition(event.latLng)
    updateFormWithPosition(event.latLng, addressInput, latInput, lngInput)
  })

  // Use current location if requested
  if (pickerOptions.useCurrentLocation) {
    getCurrentLocation()
      .then((position) => {
        centerMap(position, pickerOptions.zoom)
        updateMarkerPosition(position)
        updateFormWithPosition(position, addressInput, latInput, lngInput)
      })
      .catch((error) => {
        console.warn("Error getting current location:", error)
        // Fall back to default center
      })
  }

  // Helper function to update form with position
  function updateFormWithPosition(position, addressInput, latInput, lngInput) {
    // Update lat/lng inputs
    const lat = typeof position.lat === "function" ? position.lat() : position.lat
    const lng = typeof position.lng === "function" ? position.lng() : position.lng
    
    latInput.value = lat
    lngInput.value = lng

    // Update address input via reverse geocoding
    reverseGeocode(position)
      .then((address) => {
        if (address) {
          addressInput.value = address
        }
      })
      .catch((error) => {
        console.error("Error reverse geocoding:", error)
      })
  }

  // Return an object with control methods
  return {
    map: mapInstance,
    marker: pickerMarker,
    autocomplete: autocompleteInstance,
    
    getPosition: () => {
      return {
        lat: parseFloat(latInput.value),
        lng: parseFloat(lngInput.value),
        address: addressInput.value
      }
    },
    
    setPosition: (position) => {
      centerMap(position)
      updateMarkerPosition(position)
      updateFormWithPosition(position, addressInput, latInput, lngInput)
    }
  }
}

export default {
  initMap,
  addMarker,
  centerMap,
  getMarkerPosition,
  updateMarkerPosition,
  geocodeAddress,
  reverseGeocode,
  getCurrentLocation,
  initAutocomplete,
  initMapPicker
}

